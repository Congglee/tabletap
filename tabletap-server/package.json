{
  "name": "tabletap-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "dev:prod": "cross-env NODE_ENV=production nodemon",
    "dev:staging": "cross-env NODE_ENV=staging nodemon",
    "build": "rimraf ./dist && tsc && tsc-alias",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "start:staging": "cross-env NODE_ENV=staging node dist/index.js",
    "db:format": "prisma format",
    "db:validate": "npm run db:validate:dev",
    "db:validate:dev": "dotenv -e .env.development -o -- prisma validate",
    "db:validate:staging": "dotenv -e .env.staging -o -- prisma validate",
    "db:validate:prod": "dotenv -e .env.production -o -- prisma validate",
    "db:generate": "npm run db:generate:dev",
    "db:generate:dev": "dotenv -e .env.development -o -- prisma generate",
    "db:generate:staging": "dotenv -e .env.staging -o -- prisma generate",
    "db:generate:prod": "dotenv -e .env.production -o -- prisma generate",
    "db:studio": "npm run db:studio:dev",
    "db:studio:dev": "dotenv -e .env.development -o -- prisma studio",
    "db:studio:staging": "dotenv -e .env.staging -o -- prisma studio",
    "db:studio:prod": "dotenv -e .env.production -o -- prisma studio",
    "db:migrate:dev": "dotenv -e .env.development -o -- prisma migrate dev",
    "db:deploy:staging": "dotenv -e .env.staging -o -- prisma migrate deploy",
    "db:deploy:prod": "dotenv -e .env.production -o -- prisma migrate deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.4.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^5.16.1",
    "prisma-dbml-generator": "^0.12.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@fastify/auth": "^4.6.1",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.16.1",
    "bcrypt": "^5.1.1",
    "croner": "^8.1.0",
    "dotenv": "^16.4.5",
    "fast-jwt": "^4.0.1",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^2.0.0",
    "ms": "^2.1.3",
    "zod": "^3.23.8"
  }
}
